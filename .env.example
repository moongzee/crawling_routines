# 이 파일을 복사해서 .env 로 이름을 바꾸고 값을 채워주세요.
#   copy .env.example .env      (Windows)

# --- AWS 자격증명 / S3 ---
aws_access_key_id=YOUR_ACCESS_KEY
aws_secret_access_key=YOUR_SECRET_KEY
bucket_name=your-s3-bucket-name

# --- 선택 항목 (없으면 기본값 사용) ---
# S3 공통 상위 prefix (선택). 비워두면 소스명부터 시작.
#   최종 경로: s3://{bucket_name}/{s3_root_prefix}/{source}/{source}_YYYYMMDD.parquet
#   예) s3_root_prefix=snxbest  ->  snxbest/pop_keyword/pop_keyword_20260703.parquet
#                                   snxbest/best_item/best_item_20260703.parquet
#   비워두면            ->        pop_keyword/pop_keyword_20260703.parquet
#                                 best_item/best_item_20260703.parquet
s3_root_prefix=
# AWS 리전
aws_region=ap-northeast-2
